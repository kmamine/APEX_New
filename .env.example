# APEX configuration. Copy to `.env` and adjust. All vars are prefixed APEX_.

# --- UI / server (preserved from the legacy app) ---
APEX_HOST=127.0.0.1
APEX_PORT=8000
APEX_SHARE=false
APEX_PROFILES_DIR=data/profiles
APEX_UPLOADS_DIR=data/uploads
APEX_RUNS_DIR=data/runs
APEX_AUTO_SAVE=true

# --- Backend selection ---
# backend_mode: local | api | fake
APEX_BACKEND_MODE=local
# Optional per-capability overrides (default to backend_mode if unset):
# APEX_CHAT_BACKEND=local
# APEX_EDITOR_BACKEND=local

# --- MLLM (orchestrator + judge), served via vLLM (OpenAI-compatible) ---
APEX_VLLM_BASE_URL=http://localhost:50033/v1
APEX_VLLM_API_KEY=dummy-key
APEX_MLLM_MODEL=google/gemma-4-E4B-it
APEX_MLLM_TEMPERATURE=0.4
APEX_MLLM_MAX_TOKENS=1024

# --- Image editor ---
APEX_EDITOR_MODEL=Qwen/Qwen-Image-Edit-2511
APEX_EDITOR_DEVICE=cuda:1
APEX_NUM_INFERENCE_STEPS=45
APEX_TRUE_CFG_SCALE=4.0
# Hosted editor (backend_mode=api):
# APEX_REPLICATE_API_TOKEN=

# --- Quality thresholds & loop policy ---
APEX_IDENTITY_THRESHOLD=0.35
APEX_JUDGE_THRESHOLD=7.0
APEX_SHARPNESS_MIN=100.0
APEX_AESTHETIC_MIN=5.0
APEX_IQA_MIN=0.0
APEX_MAX_ITERATIONS=5
APEX_MAX_IDENTITY_FAILS=2
# Comma-separated; omit to enable all: identity,face,sharpness,aesthetic,iqa
# APEX_ENABLED_METRICS=identity,face,sharpness

# --- Misc ---
APEX_MODEL_CACHE=models
